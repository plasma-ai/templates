{
  "name": "{{ cookiecutter.project.name }}",
  "displayName": "{{ cookiecutter.project.title }}",
  "version": "{{ cookiecutter.project.version }}",
  "description": "{{ cookiecutter.project.description }}",
  "author": {
    "name": "{{ cookiecutter.project.authors[0].name }}",
    "email": "{{ cookiecutter.project.authors[0].email }}"{% if cookiecutter.urls.domain %},
    "url": "https://{{ cookiecutter.urls.domain }}"
{%- endif %}
  },
  "skills": ["./{{ cookiecutter.project.name }}/skills"],
  "repository": "https://github.com/{{ cookiecutter.github.org or cookiecutter.github.user }}/{{ cookiecutter.github.repo }}",
  "keywords": ["{{ cookiecutter.project.name }}"]
}
